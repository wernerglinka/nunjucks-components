{
  "name": "nunjucks-components",
  "version": "0.3.0",
  "description": "A reference library for Metalsmith in 2025",
  "type": "module",
  "keywords": [
    "metalsmith",
    "starter",
    "components",
    "structured-content",
    "static-site-generator"
  ],
  "author": "werner@glinka.co",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wernerglinka/nunjucks-components.git"
  },
  "scripts": {
    "build": "metalsmith -c metalsmith.js --env NODE_ENV=production && node scripts/package-icons.js",
    "build:debug": "DEBUG=metalsmith-optimize-html NODE_ENV=production node metalsmith.js && node scripts/package-icons.js",
    "build:verify": "NODE_ENV=production node metalsmith.js",
    "start": "NODE_ENV=development node metalsmith.js --watch",
    "start:debug": "NODE_ENV=development DEBUG=@metalsmith* node metalsmith.js --watch",
    "serve": "browser-sync start --server 'build'",
    "test": "mocha test/**/*.test.js",
    "test:watch": "mocha test/**/*.test.js --watch",
    "format": "prettier --write \"**/*.{js,json,njk,css}\"",
    "lint": "eslint --fix .",
    "lint:css": "stylelint \"lib/**/*.css\" --fix",
    "fix": "npm run format && npm run lint && npm run lint:css",
    "depcheck": "depcheck",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "test:install": "./scripts/test-installation.sh"
  },
  "devDependencies": {
    "auto-changelog": "^2.5.1",
    "browser-sync": "^3.0.4",
    "eslint": "^10.4.0",
    "gray-matter": "^4.0.3",
    "mocha": "^11.7.5",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "release-it": "^20.0.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "@metalsmith/collections": "^2.0.0",
    "@metalsmith/drafts": "^1.3.0",
    "@metalsmith/layouts": "^3.0.0",
    "@metalsmith/permalinks": "^3.2.0",
    "@swup/head-plugin": "^2.3.1",
    "@swup/preload-plugin": "^3.2.11",
    "@swup/scroll-plugin": "^4.0.0",
    "@wernerglinka/marked-directive-block": "^1.0.0",
    "@wernerglinka/marked-extensions-shared": "^1.0.0",
    "@wernerglinka/marked-image-with-class": "^1.0.0",
    "@wernerglinka/marked-link-with-class": "^1.0.0",
    "@wernerglinka/marked-paragraph-with-class": "^1.0.1",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "cssnano": "^8.0.1",
    "depcheck": "^1.4.7",
    "js-yaml": "^4.1.1",
    "jstransformer-nunjucks": "^1.2.0",
    "marked": "^18.0.4",
    "marked-highlight": "^2.2.4",
    "metalsmith": "2.6.3",
    "metalsmith-blog-lists": "^2.1.1",
    "metalsmith-bundled-components": "^1.0.0",
    "metalsmith-menu-plus": "^0.3.0",
    "metalsmith-optimize-html": "^0.10.0",
    "metalsmith-optimize-images": "^0.12.0",
    "metalsmith-safe-links": "^2.1.0",
    "metalsmith-search": "^1.0.1",
    "metalsmith-sectioned-blog-pagination": "^1.3.1",
    "metalsmith-seo": "^1.1.3",
    "metalsmith-simple-pagination": "^0.1.0",
    "metalsmith-static-files": "^3.0.2",
    "metalsmith-unified-markdown": "^0.0.4",
    "npm-check-updates": "^22.2.0",
    "postcss": "^8.5.15",
    "prismjs": "^1.30.0",
    "rehype-highlight": "^7.0.2",
    "swup": "^4.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
