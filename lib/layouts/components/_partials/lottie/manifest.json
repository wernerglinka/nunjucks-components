{
  "name": "lottie",
  "type": "partial",
  "styles": ["lottie.css"],
  "scripts": [],
  "requires": [],
  "validation": {
    "required": ["src"],
    "properties": {
      "src": {
        "type": "string"
      },
      "speed": {
        "type": "number",
        "default": 1
      },
      "control.loop": {
        "type": "boolean"
      },
      "control.autoplay": {
        "type": "boolean"
      }
    }
  },
  "fields": {
    "src": {
      "widget": "text",
      "label": "Lottie JSON URL",
      "default": ""
    },
    "speed": {
      "widget": "text",
      "label": "Playback speed",
      "default": "1"
    },
    "control": {
      "loop": {
        "widget": "checkbox",
        "label": "Loop",
        "default": true
      },
      "autoplay": {
        "widget": "checkbox",
        "label": "Autoplay",
        "default": true
      }
    }
  }
}
