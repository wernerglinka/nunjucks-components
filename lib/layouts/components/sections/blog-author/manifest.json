{
  "name": "blog-author",
  "type": "section",
  "styles": ["blog-author.css"],
  "scripts": [],
  "requires": ["text", "image", "commons"],
  "context": ["data.author"],
  "validation": {
    "required": ["sectionType"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "blog-author"
      },
      "isReverse": {
        "type": "boolean"
      },
      "isDisabled": {
        "type": "boolean"
      },
      "logoWidth": {
        "type": "number"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "containerFields.noMargin.top": {
        "type": "boolean"
      },
      "containerFields.noMargin.bottom": {
        "type": "boolean"
      },
      "containerFields.noPadding.top": {
        "type": "boolean"
      },
      "containerFields.noPadding.bottom": {
        "type": "boolean"
      },
      "containerFields.background.isDark": {
        "type": "boolean"
      }
    }
  },
  "fields": {
    "name": {
      "widget": "select",
      "label": "Author",
      "source": { "data": "author", "valueKey": "name" },
      "default": ""
    },
    "isReverse": {
      "widget": "checkbox",
      "label": "Reverse layout",
      "default": false
    },
    "logoWidth": {
      "widget": "number",
      "label": "Social logo width (px)",
      "default": 30
    },
    "$extends": ["commons"]
  }
}
