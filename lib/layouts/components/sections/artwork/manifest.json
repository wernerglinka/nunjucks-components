{
  "name": "artwork",
  "type": "section",
  "styles": ["artwork.css"],
  "scripts": [],
  "requires": ["text", "image", "commons"],
  "validation": {
    "required": ["sectionType", "image"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "artwork"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "text.title": {
        "type": "string"
      },
      "text.prose": {
        "type": "string"
      },
      "image.src": {
        "type": "string"
      },
      "image.alt": {
        "type": "string"
      },
      "image.caption": {
        "type": "string"
      },
      "artworkProperties.type": {
        "type": "string"
      },
      "artworkProperties.year": {
        "type": "number"
      },
      "artworkProperties.materials": {
        "type": "string"
      },
      "artworkProperties.dimensions": {
        "type": "object"
      },
      "artworkProperties.status": {
        "type": "string"
      }
    }
  },
  "fields": {
    "text": {
      "$use": "text"
    },
    "image": {
      "$use": "image"
    },
    "artworkProperties": {
      "type": {
        "widget": "text",
        "label": "Type",
        "default": ""
      },
      "year": {
        "widget": "text",
        "label": "Year",
        "default": ""
      },
      "materials": {
        "widget": "text",
        "label": "Materials",
        "default": ""
      },
      "dimensions": {
        "width": {
          "widget": "text",
          "label": "Width",
          "default": ""
        },
        "height": {
          "widget": "text",
          "label": "Height",
          "default": ""
        },
        "depth": {
          "widget": "text",
          "label": "Depth",
          "default": ""
        },
        "unit": {
          "widget": "select",
          "label": "Unit",
          "enum": ["in", "cm"],
          "default": "in"
        }
      },
      "status": {
        "widget": "text",
        "label": "Status",
        "default": ""
      }
    },
    "$extends": ["commons"]
  }
}
