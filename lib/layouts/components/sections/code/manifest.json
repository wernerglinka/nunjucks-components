{
  "name": "code",
  "type": "section",
  "styles": ["code.css"],
  "scripts": ["code.js"],
  "requires": ["commons"],
  "validation": {
    "required": ["sectionType", "code"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "code"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "code.content": {
        "type": "string",
        "description": "A fenced markdown code block (```lang ... ```); highlighted by Shiki via mdToHTML"
      },
      "code.filename": {
        "type": "string",
        "description": "Optional filename to display"
      },
      "code.showCopy": {
        "type": "boolean",
        "default": true,
        "description": "Show copy to clipboard button"
      }
    }
  },
  "fields": {
    "code": {
      "content": {
        "widget": "textarea",
        "label": "Code (fenced markdown block, e.g. ```js … ```)",
        "default": ""
      },
      "filename": {
        "widget": "text",
        "label": "Filename (optional)",
        "default": ""
      },
      "showCopy": {
        "widget": "checkbox",
        "label": "Show copy button",
        "default": true
      }
    },
    "$extends": ["commons"]
  }
}
