{
  "name": "testimonial",
  "type": "section",
  "styles": ["testimonial.css"],
  "scripts": [],
  "requires": ["ctas", "text", "image", "commons"],
  "validation": {
    "required": ["sectionType"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "testimonial"
      },
      "isReverse": {
        "type": "boolean"
      },
      "isDisabled": {
        "type": "boolean"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "containerFields.noMargin.top": {
        "type": "boolean"
      },
      "containerFields.noMargin.bottom": {
        "type": "boolean"
      },
      "containerFields.noPadding.top": {
        "type": "boolean"
      },
      "containerFields.noPadding.bottom": {
        "type": "boolean"
      },
      "containerFields.background.isDark": {
        "type": "boolean"
      }
    }
  },
  "fields": {
    "isReverse": {
      "widget": "checkbox",
      "label": "Reverse layout",
      "default": false
    },
    "quote": {
      "text": {
        "widget": "markdown",
        "label": "Quote",
        "default": ""
      },
      "cite": {
        "widget": "text",
        "label": "Citation URL (optional)",
        "default": ""
      }
    },
    "quotee": {
      "portrait": {
        "$use": "image"
      },
      "name": {
        "widget": "text",
        "label": "Name",
        "default": ""
      },
      "title": {
        "widget": "text",
        "label": "Title",
        "default": ""
      },
      "company": {
        "widget": "text",
        "label": "Company",
        "default": ""
      },
      "logo": {
        "widget": "image",
        "label": "Company logo (optional)",
        "default": ""
      }
    },
    "$extends": ["commons"]
  }
}
