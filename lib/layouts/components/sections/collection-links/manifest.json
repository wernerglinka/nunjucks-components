{
  "name": "collection-links",
  "type": "aside",
  "styles": ["collection-links.css"],
  "scripts": [],
  "requires": ["commons"],
  "context": ["collection"],
  "plugins": ["@metalsmith/collections"],
  "validation": {
    "required": ["sectionType"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "collection-links"
      },
      "isDisabled": {
        "type": "boolean"
      }
    }
  },
  "fields": {
    "collectionName": {
      "widget": "select",
      "label": "Collection",
      "source": { "collections": true },
      "default": "blog"
    },
    "$extends": ["commons"]
  }
}
