{
  "name": "related-posts",
  "type": "section",
  "styles": ["related-posts.css"],
  "scripts": [],
  "requires": ["text", "collection-card", "commons"],
  "context": ["collections"],
  "plugins": ["@metalsmith/collections"],
  "validation": {
    "required": ["sectionType"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "related-posts"
      },
      "hasCard": {
        "type": "boolean"
      },
      "selections": {
        "type": "array"
      },
      "isDisabled": {
        "type": "boolean"
      }
    }
  }
}
