{
  "name": "multi-tab",
  "type": "section",
  "styles": ["multi-tab.css"],
  "scripts": ["multi-tab.js"],
  "requires": ["text", "commons"],
  "context": ["data", "collections", "urlPath"],
  "validation": {
    "required": ["sectionType", "tabs"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "multi-tab"
      },
      "defaultTab": {
        "type": "string"
      },
      "tabs": {
        "type": "array"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "text.title": {
        "type": "string"
      },
      "text.titleTag": {
        "type": "string"
      }
    }
  },
  "fields": {
    "text": {
      "$use": "text"
    },
    "defaultTab": {
      "widget": "text",
      "label": "Default tab key (optional)",
      "default": ""
    },
    "tabs": {
      "widget": "array",
      "label": "Tabs (each pane is a nested section)",
      "items": {
        "key": {
          "widget": "text",
          "label": "Key",
          "default": ""
        },
        "label": {
          "widget": "text",
          "label": "Label",
          "default": ""
        },
        "pane": {
          "sectionType": {
            "widget": "text",
            "label": "Pane section type",
            "default": ""
          }
        }
      }
    },
    "$extends": ["commons"]
  }
}
