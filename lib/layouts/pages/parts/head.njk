<head>
  {# Per-page SEO with site-level fallbacks #}
  {% set pageTitle = seo.title or card.title or metadata.site.title %}
  {% set pageDescription = seo.description or card.description or metadata.site.description %}
  {% set pageImage = seo.socialImage or metadata.site.defaultImage %}
  {% if seo.canonicalURL %}
    {% set canonicalURL = seo.canonicalURL %}
  {% elif permalink and permalink != '.' %}
    {% set canonicalURL = metadata.site.url + '/' + permalink + '/' %}
  {% else %}
    {% set canonicalURL = metadata.site.url + '/' %}
  {% endif %}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}" />
  {% if seo.keywords %}<meta name="keywords" content="{{ seo.keywords }}" />{% endif %}
  <meta name="author" content="Werner Glinka" />
  <meta name="generator" content="metalsmith" />

  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDescription }}" />
  <meta property="og:type" content="{{ 'article' if card.date else 'website' }}" />
  <meta property="og:url" content="{{ canonicalURL }}" />
  <meta property="og:site_name" content="{{ metadata.site.title }}" />
  <meta property="og:locale" content="{{ metadata.site.locale }}" />
  {% if pageImage %}<meta property="og:image" content="{{ metadata.site.url }}{{ pageImage }}" />{% endif %}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDescription }}" />
  {% if pageImage %}<meta name="twitter:image" content="{{ metadata.site.url }}{{ pageImage }}" />{% endif %}

  <meta name="google-site-verification" content="QqNO2zBa-MXZeMNSn4xIVhnalhd84ADMLE6uwLIy4Ms" />
  
  <meta charset="utf-8" />
  <meta httpEquiv="x-ua-compatible" content="ie=edge" />
  <meta name="HandheldFriendly" content="True" />
  <meta name="MobileOptimized" content="320" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta httpEquiv="cleartype" content="on" />
  <meta httpEquiv="Accept-CH" content="DPR, Viewport-Width, Width" />

  {# Icons #} {# generated at
  https://realfavicongenerator.net/favicon_result?file_id=p1ftthvcomq191neufes1ch51poc6#.YivO7hDMJqs #}
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
  <link rel="manifest" href="/assets/icons/site.webmanifest" />
  <link rel="mask-icon" href="/assets/icons/safari-pinned-tab.svg" color="#5bbad5" />
  <meta name="msapplication-TileColor" content="#da532c" />
  <meta name="theme-color" content="#ffffff" />

  <link rel="canonical" href="{{ canonicalURL }}" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500&family=Open+Sans:wght@300;500&display=swap"
  />
  <link rel="stylesheet" href="/assets/main.css" />
</head>
